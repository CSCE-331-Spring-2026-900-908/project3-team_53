PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# Database configuration - dont change these
DB_SYNCHRONIZE=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Google Sign-In (ID token verification) — same client ID as frontend
GOOGLE_CLIENT_ID=

# Application JWT (set a long random secret in production)
JWT_SECRET=
# Token lifetime in seconds (default 604800 = 7 days)
JWT_EXPIRES_SEC=604800

# Google Gemini API key for the kiosk chatbot assistant
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
